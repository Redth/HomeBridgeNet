<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <LangVersion>latest</LangVersion>
    <!-- Plugin authors get a plain class library. Copy deps (incl. HomeBridge.Net.dll) to output. -->
    <CopyLocalLockFileAssemblies>true</CopyLocalLockFileAssemblies>
  </PropertyGroup>

  <ItemGroup>
    <ProjectReference Include="..\..\src\HomeBridge.Net\HomeBridge.Net.csproj" />
    <!-- Build-order only: ensure the MSBuild task assembly exists before this project's PackHomebridgePlugin
         target runs. Not referenced as a compile-time assembly. -->
    <ProjectReference Include="..\..\src\HomeBridge.Net.Build\HomeBridge.Net.Build.csproj"
                      ReferenceOutputAssembly="false"
                      SkipGetTargetFrameworkProperties="true"
                      PrivateAssets="all" />
  </ItemGroup>

  <!-- Dev wiring for the build tooling. A real plugin gets this from the HomeBridge.Net.Build
       NuGet package automatically; here we point at the locally-built task and import its targets.
       Uses $(Configuration) so it works under both Debug and Release. -->
  <PropertyGroup>
    <Version>1.0.0</Version>
    <Description>Sample Homebridge platform plugin implemented in C#/.NET with HomeBridge.Net.</Description>
    <HomeBridgeNetBuildTasksAssembly>$(MSBuildThisFileDirectory)..\..\src\HomeBridge.Net.Build\bin\$(Configuration)\netstandard2.0\HomeBridge.Net.Build.Tasks.dll</HomeBridgeNetBuildTasksAssembly>
  </PropertyGroup>
  <Import Project="..\..\src\HomeBridge.Net.Build\build\HomeBridge.Net.Build.props" />
  <Import Project="..\..\src\HomeBridge.Net.Build\build\HomeBridge.Net.Build.targets" />

</Project>
